function VistaAdmin({ platillos, setPlatillos, mostrarNotificacion }) {
  const [autenticado, setAutenticado] = useState(false);
  const [pin, setPin] = useState('');
  const [editando, setEditando] = useState(null);
  const [form, setForm] = useState({ nombre: '', precio: 0, descripcion: '', imagen: '', esEspecialidad: false });

  const login = (e) => {
    e.preventDefault();
    if (pin === "1234") setAutenticado(true);
    else mostrarNotificacion("Acceso Denegado");
  };

  const guardar = () => {
    if (!form.nombre) return;
    const nuevos = editando === 'nuevo' ? [...platillos, { ...form, id: Date.now() }] : platillos.map(p => p.id === editando ? { ...form, id: editando } : p);
    setPlatillos(nuevos);
    setEditando(null);
    mostrarNotificacion("Cambios Guardados");
  };

  if (!autenticado) return (
    <div className="max-w-md mx-auto mt-32 p-16 bg-white rounded-[4rem] shadow-2xl text-center border-t-[20px] border-orange-600">
      <h2 className="text-3xl font-black mb-10 uppercase italic">Admin Login</h2>
      <form onSubmit={login}>
        <input type="password" value={pin} onChange={e => setPin(e.target.value)} placeholder="PIN" className="w-full p-6 border-4 border-orange-50 rounded-3xl mb-8 text-center text-3xl font-black tracking-widest outline-none" />
        <button className="w-full bg-orange-600 text-white py-6 rounded-3xl font-black uppercase tracking-widest shadow-xl">Entrar</button>
      </form>
    </div>
  );

  return (
    <div className="max-w-6xl mx-auto px-6 py-20">
      <div className="flex justify-between items-center mb-12">
        <h2 className="text-5xl font-black text-orange-800 uppercase italic">Control de Menú</h2>
        <button onClick={() => { setEditando('nuevo'); setForm({ nombre: '', precio: 0, descripcion: '', imagen: '', esEspecialidad: false }); }} className="bg-green-600 text-white px-8 py-4 rounded-3xl font-black flex items-center shadow-lg"><Plus className="mr-2"/> Nuevo</button>
      </div>

      {editando && (
        <div className="bg-white p-12 rounded-[4rem] shadow-2xl mb-20 border-t-[15px] border-orange-600 space-y-6">
          <input type="text" value={form.nombre} onChange={e => setForm({...form, nombre: e.target.value})} placeholder="Nombre" className="w-full p-6 border-2 border-gray-50 rounded-2xl text-xl font-black uppercase" />
          <input type="number" value={form.precio} onChange={e => setForm({...form, precio: parseFloat(e.target.value)})} placeholder="Precio" className="w-full p-6 border-2 border-gray-50 rounded-2xl text-3xl font-black text-orange-600" />
          <textarea value={form.descripcion} onChange={e => setForm({...form, descripcion: e.target.value})} placeholder="Descripción" className="w-full p-6 border-2 border-gray-50 rounded-2xl font-bold italic" />
          <label className="flex items-center space-x-4 bg-orange-50 p-6 rounded-3xl cursor-pointer">
            <input type="checkbox" checked={form.esEspecialidad} onChange={e => setForm({...form, esEspecialidad: e.target.checked})} className="w-10 h-10 rounded-xl text-orange-600" />
            <span className="font-black text-xl text-orange-900 italic uppercase">Marcar como Especialidad Estrella ⭐</span>
          </label>
          <div className="flex space-x-4 pt-6">
            <button onClick={() => setEditando(null)} className="flex-1 bg-gray-100 py-6 rounded-3xl font-black uppercase tracking-widest">Cancelar</button>
            <button onClick={guardar} className="flex-1 bg-orange-600 text-white py-6 rounded-3xl font-black uppercase tracking-widest shadow-xl">Guardar</button>
          </div>
        </div>
      )}

      <div className="bg-white rounded-[4rem] shadow-2xl overflow-hidden border-[15px] border-white">
        <table className="w-full text-left">
          <thead className="bg-gray-900 text-white uppercase text-[10px] tracking-widest font-black">
            <tr><th className="p-8">Platillo</th><th className="p-8">Precio</th><th className="p-8 text-center">Tipo</th><th className="p-8 text-right">Acciones</th></tr>
          </thead>
          <tbody className="divide-y-[10px] divide-gray-50">
            {platillos.map(p => (
              <tr key={p.id} className="hover:bg-orange-50 transition-colors">
                <td className="p-8 font-black text-2xl uppercase italic">{p.nombre}</td>
                <td className="p-8 font-black text-orange-600 text-3xl">${p.precio}</td>
                <td className="p-8 text-center">{p.esEspecialidad ? "⭐" : "-"}</td>
                <td className="p-8 text-right flex justify-end space-x-4">
                  <button onClick={() => { setEditando(p.id); setForm(p); }} className="p-4 bg-blue-50 text-blue-500 rounded-2xl hover:bg-blue-600 hover:text-white transition-all"><Edit2/></button>
                  <button onClick={() => setPlatillos(platillos.filter(x => x.id !== p.id))} className="p-4 bg-red-50 text-red-500 rounded-2xl hover:bg-red-600 hover:text-white transition-all"><Trash2/></button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}
