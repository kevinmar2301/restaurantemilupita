        <div className="absolute top-4 right-4 bg-white/95 backdrop-blur-md px-4 py-1 rounded-full font-black text-orange-600 shadow-xl text-lg tracking-tighter">
          ${platillo.precio}
        </div>
      </div>
      <div className="p-8 flex flex-col flex-1">
        <h3 className="font-black text-xl text-gray-800 mb-2 uppercase italic leading-none">{platillo.nombre}</h3>
        <p className="text-gray-400 text-[10px] mb-6 flex-1 italic">{platillo.descripcion}</p>
        <button onClick={() => abrirPersonalizacion(platillo)} className="w-full bg-orange-600 text-white py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-orange-700 transition-all shadow-lg active:scale-95">Personalizar</button>
      </div>
    </article>
  );
}

