// --- COMPONENTE 3D: PLATILLO GIRATORIO ---
const RotatingDish3D = () => {
  const mountRef = useRef(null);

  useEffect(() => {
    let renderer, scene, camera, plate, foodGroup;
    let animationId;

    const initScene = () => {
      const THREE = window.THREE;
      if (!mountRef.current || !THREE) return;

      scene = new THREE.Scene();
      camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
      camera.position.set(0, 2, 5);
      camera.lookAt(0, 0, 0);

      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setSize(400, 400);
      mountRef.current.appendChild(renderer.domElement);

      const ambientLight = new THREE.AmbientLight(0xffffff, 0.7);
      scene.add(ambientLight);
      const pointLight = new THREE.PointLight(0xffffff, 1);
      pointLight.position.set(5, 5, 5);
      scene.add(pointLight);

      // Plato
      const plateGeo = new THREE.CylinderGeometry(2, 1.8, 0.1, 32);
      const plateMat = new THREE.MeshStandardMaterial({ color: 0xffffff });
      plate = new THREE.Mesh(plateGeo, plateMat);
      scene.add(plate);

      foodGroup = new THREE.Group();
      for (let i = 0; i < 3; i++) {
        const itemGeo = new THREE.BoxGeometry(0.8, 0.3, 1.2);
        const itemMat = new THREE.MeshStandardMaterial({ color: 0xe67e22 });
        const item = new THREE.Mesh(itemGeo, itemMat);
        item.position.x = (i - 1) * 0.6;
        item.position.y = 0.2;
        item.rotation.y = Math.random();
        foodGroup.add(item);
      }

      const sauceGeo = new THREE.TorusGeometry(0.8, 0.2, 8, 32);
      const sauceMat = new THREE.MeshStandardMaterial({ color: 0x27ae60 });
      const sauce = new THREE.Mesh(sauceGeo, sauceMat);
      sauce.rotation.x = Math.PI / 2;
      sauce.position.y = 0.15;
      foodGroup.add(sauce);
      scene.add(foodGroup);

      const animate = () => {
        animationId = requestAnimationFrame(animate);
        if (plate) plate.rotation.y += 0.01;
        if (foodGroup) foodGroup.rotation.y += 0.01;
        renderer.render(scene, camera);
      };
      animate();
    };

    if (typeof window.THREE === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
      script.onload = initScene;
      document.head.appendChild(script);
    } else {
      initScene();
    }

    return () => {
      cancelAnimationFrame(animationId);
      if (mountRef.current && renderer) {
        mountRef.current.innerHTML = '';
      }
    };
  }, []);

  return <div ref={mountRef} className="w-[300px] h-[300px] md:w-[400px] md:h-[400px] flex items-center justify-center cursor-move" />;
};

